# Copy this file to .env and fill in your OAuth client IDs.
# NEVER commit .env to version control.

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Application type: Web application (for web) or Android (for APK)
# Authorized redirect URIs: https://yourdomain.com/oauth/callback
# For Android: add custom scheme URI: com.cowork.notepad://oauth/callback
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Azure Portal → App registrations → Authentication → Add platform
# Platform: Mobile and desktop applications
# Custom redirect URI: com.cowork.notepad://oauth/callback
VITE_ONEDRIVE_CLIENT_ID=YOUR_AZURE_APP_CLIENT_ID
